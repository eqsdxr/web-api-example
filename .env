# postgresql://user:password@host:port/dbname
# For local usage
DATABASE_URI=postgresql+psycopg://postgres:root@localhost:5432/app
# For usage in a docker container
#DATABASE_URI=postgresql+psycopg://postgres:root@database:5432/app
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
